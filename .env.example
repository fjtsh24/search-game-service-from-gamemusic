# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password

# Supabase CLI (supabase db query --linked で使用)
SUPABASE_ACCESS_TOKEN=your-access-token
SUPABASE_PROJECT_REF=your-project-ref

# ── Steam ─────────────────────────────────────────────────────────────────────
STEAM_API_KEY=your-steam-api-key
# ローカル開発: http://localhost:8000/auth/steam/callback
# 本番:        https://search-game-service-api.fly.dev/auth/steam/callback
STEAM_OPENID_RETURN_URL=http://localhost:8000/auth/steam/callback

# ── Last.fm ───────────────────────────────────────────────────────────────────
LASTFM_API_KEY=your-lastfm-api-key

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_API_KEY=your-youtube-api-key

# ── IGDB (Twitch) ─────────────────────────────────────────────────────────────
IGDB_CLIENT_ID=your-igdb-client-id
IGDB_CLIENT_SECRET=your-igdb-client-secret

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# ── App ───────────────────────────────────────────────────────────────────────
# SESSION_SECRET: python3 -c "import secrets; print(secrets.token_hex(32))" で生成
SESSION_SECRET=change-this-to-a-long-random-string

# ローカル開発: http://localhost:3000
# 本番:        https://your-project.vercel.app
FRONTEND_URL=http://localhost:3000

ENVIRONMENT=development

# ── Web (web/.env.local にも設定が必要) ──────────────────────────────────────
# ローカル開発: http://localhost:8000
# 本番:        https://search-game-service-api.fly.dev  (Vercel の環境変数に設定)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── GitHub Actions Secrets (リポジトリ Settings → Secrets → Actions) ──────────
# FLY_API_TOKEN         : fly auth token の出力値
# SUPABASE_URL          : 上と同じ
# SUPABASE_SERVICE_ROLE_KEY : 上と同じ
# UPSTASH_REDIS_URL     : 上と同じ
# UPSTASH_REDIS_TOKEN   : 上と同じ
# STEAM_API_KEY         : 上と同じ
# YOUTUBE_API_KEY       : 上と同じ
# LASTFM_API_KEY        : 上と同じ
